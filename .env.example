# Postgres connection string. На Vercel создаётся автоматически
# при добавлении интеграции Vercel Postgres / Neon.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Admin auth — обязательно поменяй перед деплоем
ADMIN_PASSWORD="change-me"
ADMIN_SESSION_SECRET="change-me-very-secret-string-32+chars"

# Telegram-уведомления о новых заявках (опционально)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Канонический URL — Vercel сам подставит при деплое
NEXT_PUBLIC_SITE_URL="https://event-kvartal.vercel.app"
